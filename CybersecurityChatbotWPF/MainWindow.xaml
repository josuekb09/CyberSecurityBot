<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" Height="650" Width="750"
        Background="#0B0F19" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" CornerRadius="8" Padding="10" Margin="0,0,0,15" BorderBrush="#1F2937" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🛡️ CYBERSECURITY CHATBOT INTERACTIVE 🛡️" Foreground="#22D3EE" FontSize="16" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center"/>
                <TextBlock Text="   _____       _               ____        _   &#x0a;  / ___|   _  | |__   ___ _ __| __ )  ___ | |_ &#x0a; | |  | | | | | '_ \ / _ \ '__|  _ \ / _ \| __|&#x0a; | |__| |_| | | |_) |  __/ |  | |_) | (_) | |_ &#x0a;  \____\__, | |_.__/ \___|_|  |____/ \___/ \__|&#x0a;       |___/                                   " 
                           Foreground="#06B6D4" FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#111827" CornerRadius="8" BorderBrush="#1F2937" BorderThickness="1" Padding="10">
            <ScrollViewer x:Name="ChatScroll">
                <TextBlock x:Name="ChatDisplay" Foreground="#F3F4F6" FontSize="13" FontFamily="Consolas" TextWrapping="Wrap" LineHeight="20"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtInput" Grid.Column="0" Background="#1F2937" Foreground="#F3F4F6" BorderBrush="#374151" BorderThickness="1" 
                     Padding="10" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" KeyDown="TxtInput_KeyDown"/>

            <Button x:Name="BtnSend" Grid.Column="1" Content="SEND COMMAND" Width="140" Margin="10,0,0,0" Padding="10"
                    Background="#0891B2" Foreground="White" FontWeight="Bold" FontFamily="Consolas" Click="BtnSend_Click"/>
        </Grid>
    </Grid>
</Window>