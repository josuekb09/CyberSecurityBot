<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Assistant"
        Height="780"
        Width="1080"
        MinHeight="720"
        MinWidth="980"
        Background="#0F172A"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <SolidColorBrush x:Key="PageBackground" Color="#0F172A"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#111827"/>
        <SolidColorBrush x:Key="CardBackground" Color="#172033"/>
        <SolidColorBrush x:Key="BorderColor" Color="#263449"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent" Color="#38BDF8"/>
        <SolidColorBrush x:Key="AccentDark" Color="#0284C7"/>
        <SolidColorBrush x:Key="Success" Color="#16A34A"/>
        <SolidColorBrush x:Key="Danger" Color="#DC2626"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentDark}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDark}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="38"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Success}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Danger}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,4,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1B2537"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="22"
                Margin="0,0,0,18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="46"
                        Height="46"
                        CornerRadius="12"
                        Background="#0B1220"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Margin="0,0,16,0">
                    <TextBlock Text="CS"
                               Foreground="{StaticResource Accent}"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Cybersecurity Awareness Assistant"
                               Foreground="{StaticResource PrimaryText}"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="Task management, reminders, quiz, NLP simulation and activity tracking"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="13"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#0B1220"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="14,8"
                        VerticalAlignment="Center">

                    <TextBlock Text="POE Part 3"
                               Foreground="{StaticResource Accent}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs"
                    Grid.Row="1"
                    Background="{StaticResource PageBackground}"
                    BorderBrush="{StaticResource BorderColor}">

            <TabItem Header="Chat">
                <Border Background="{StaticResource PanelBackground}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="0,12,12,12"
                        Padding="18"
                        Margin="0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,14">
                            <TextBlock Text="Assistant Conversation"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Ask about passwords, phishing, privacy, scams, browsing, tasks, reminders, quiz, or activity log."
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Background="#0B1220"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">

                            <ScrollViewer x:Name="ChatScroll"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ChatDisplay"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="14"
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap"
                                           LineHeight="23"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Tasks and Reminders">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelBackground}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="0,12,12,12"
                            Padding="18"
                            Margin="0,0,0,14">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Text="Cybersecurity Task Assistant"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Task title"
                                       Foreground="{StaticResource SecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,10"/>

                            <TextBox x:Name="TaskTitleBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Description"
                                       Foreground="{StaticResource SecondaryText}"
                                       VerticalAlignment="Top"
                                       Margin="0,8,12,10"/>

                            <TextBox x:Name="TaskDescriptionBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Height="72"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Reminder"
                                       Foreground="{StaticResource SecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>

                            <Grid Grid.Row="3" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePicker x:Name="ReminderDatePicker"
                                            Grid.Column="0"
                                            Width="170"
                                            Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="or in"
                                           Foreground="{StaticResource SecondaryText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <TextBox x:Name="ReminderDaysBox"
                                         Grid.Column="2"
                                         Width="70"
                                         Margin="0,0,8,0"/>

                                <TextBlock Grid.Column="3"
                                           Text="day(s)"
                                           Foreground="{StaticResource SecondaryText}"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">

                                    <Button Content="Add Task"
                                            Width="110"
                                            Margin="6,0,0,0"
                                            Click="BtnAddTask_Click"/>

                                    <Button Content="Refresh"
                                            Width="100"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnRefreshTasks_Click"/>

                                    <Button Content="Complete"
                                            Width="110"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource SuccessButton}"
                                            Click="BtnCompleteTask_Click"/>

                                    <Button Content="Delete"
                                            Width="100"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource DangerButton}"
                                            Click="BtnDeleteTask_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBackground}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Saved Tasks"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <ListBox x:Name="TaskList"
                                     Grid.Row="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Cyber Quiz">
                <Border Background="{StaticResource PanelBackground}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="0,12,12,12"
                        Padding="22">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="Cybersecurity Knowledge Check"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="20"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Answer each question and receive immediate feedback with a final score."
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="13"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Background="#0B1220"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20">

                            <StackPanel>
                                <TextBlock x:Name="QuizQuestionText"
                                           Text="Click Start Quiz to begin."
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,18"/>

                                <StackPanel x:Name="QuizOptionsPanel"
                                            Margin="0,0,0,18"/>

                                <TextBlock x:Name="QuizFeedbackText"
                                           Foreground="#A7F3D0"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <TextBlock x:Name="QuizScoreText"
                                           Foreground="{StaticResource Accent}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">

                            <Button x:Name="BtnStartQuiz"
                                    Content="Start Quiz"
                                    Width="130"
                                    Margin="0,0,8,0"
                                    Click="BtnStartQuiz_Click"/>

                            <Button x:Name="BtnNextQuestion"
                                    Content="Submit Answer"
                                    Width="150"
                                    IsEnabled="False"
                                    Style="{StaticResource SuccessButton}"
                                    Click="BtnNextQuestion_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Activity Log">
                <Border Background="{StaticResource PanelBackground}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="0,12,12,12"
                        Padding="22">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Recent Application Activity"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="20"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Tracks tasks, reminders, quiz attempts and NLP commands."
                                           Foreground="{StaticResource SecondaryText}"
                                           FontSize="13"
                                           Margin="0,5,0,0"/>
                            </StackPanel>

                            <Button x:Name="BtnShowLog"
                                    Grid.Column="1"
                                    Content="Refresh Log"
                                    Width="130"
                                    VerticalAlignment="Center"
                                    Click="BtnShowLog_Click"/>
                        </Grid>

                        <ListBox x:Name="ActivityLogList"
                                 Grid.Row="1"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,18,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtInput"
                         Grid.Column="0"
                         Height="42"
                         VerticalAlignment="Center"
                         KeyDown="TxtInput_KeyDown"/>

                <Button x:Name="BtnSend"
                        Grid.Column="1"
                        Content="Send"
                        Width="120"
                        Margin="10,0,0,0"
                        Click="BtnSend_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>